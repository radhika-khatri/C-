        cout << "Error opening output file." << endl;
        return 1;
    }

    cout << "\nRecords popped from the Stack:" << endl;
    while (!studentStack.isEmpty()) {
        StudentRecord poppedRecord = studentStack.pop();
        cout << poppedRecord.getIDNO() << " " << poppedRecord.getNAME() << " " << poppedRecord.getDOB() << " " << poppedRecord.getCGPA() << endl;

        outputFile << poppedRecord.getIDNO() << " " << poppedRecord.getNAME() << " " << poppedRecord.getDOB() << " " << poppedRecord.getCGPA() << endl;
    }

    outputFile.close();
    return 0;
}

